class Solution {
    public int compress(char[] chars) {
       int write=0;
       int i=0;
       while(i<chars.length){
        char cur=chars[i];
        int count=0;
        while(i<chars.length && chars[i]==cur){
            i++;
            count++;
        }
        chars[write++]=cur;
        if(count>1){
            for(char c: String.valueOf(count).toCharArray()){
                chars[write++]=c;
            }
        }
       }
       return write;
    }
}
